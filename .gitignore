# ============================================================
# Content Vault - Runtime Generated Files (DO NOT COMMIT)
# ============================================================
# รูปภาพ, วิดีโอ, และไฟล์ที่โปรแกรมดาวน์โหลด/สร้างขึ้นเอง
# ไม่ต้องส่งไปกับ Git เพราะโปรแกรมจะสร้างใหม่เองอัตโนมัติ

# Downloaded Media (รูปที่ดาวน์โหลดมา)
content_vault/downloaded_media/**
!content_vault/downloaded_media/**/.gitkeep

# Generated Graphics (รูปที่โปรแกรมสร้าง)
content_vault/generated_graphics/**
!content_vault/generated_graphics/**/.gitkeep

# Logos (โลโก้ที่ดาวน์โหลด)
content_vault/logos/**
!content_vault/logos/.gitkeep

# Databases (ฐานข้อมูล SQLite)
content_vault/databases/**
!content_vault/databases/.gitkeep

# Exports CSV (ไฟล์ export)
