# Scraped third-party data (ห้าม commit — มีข้อมูลส่วนตัวของผู้อื่น)
scrapes/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Python venvs (whisper ฯลฯ)
.venv-whisper/
.venv/
venv/

# Node modules
node_modules/
**/node_modules/

# npm cache (สร้างขึ้นตอนรัน ไม่ต้อง commit)
.npm_cache/
**/.npm_cache/

# Single Clip Editor — cache ความยาวคลิป (สร้างตอนรัน)
.durations_cache.json
**/.durations_cache.json

# ค่าเฉพาะเครื่อง (ห้าม commit — แต่ละเครื่องตั้งเอง)
media-location.txt
.setup_complete

# โฟลเดอร์ media หนัก (เป็น symlink ออกไปนอกโปรแกรม)
content_vault/generated_graphics
content_vault/downloaded_media
content_vault/logos

# Build outputs
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/

# Local databases & logs
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
content_vault/databases/*.db
content_vault/databases/*.log
content_vault/databases/*.db-wal
content_vault/databases/*.db-shm

# Operating System Files
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Models and temporary renders
public/models/
public/temp_render/

# App-data key-value store (brains/ข้อมูลแอป — เป็นข้อมูลผู้ใช้ ไม่ commit)
public/app_data/

# Stock media files (generated/downloaded at runtime)
public/Voice_stock/*.mp3
public/Video_stock/
public/Sound_stock/*.mp3
public/Sound_stock/*.wav
public/Image_stock/
public/Avatar_stock/

# Keep catalog files tracked (they're config, not media)
!public/Voice_stock/sfx_catalog.json
!public/Sound_stock/sfx_catalog.json

# ============================================================
# Content Vault - Runtime Generated Files (DO NOT COMMIT)
# ============================================================
content_vault/downloaded_media/**
!content_vault/downloaded_media/**/.gitkeep

content_vault/generated_graphics/**
!content_vault/generated_graphics/**/.gitkeep

content_vault/logos/**
!content_vault/logos/.gitkeep

content_vault/databases/**
!content_vault/databases/.gitkeep

content_vault/exports_csv/**
!content_vault/exports_csv/.gitkeep
!content_vault/exports_csv/deep_research/.gitkeep

content_vault/scratch/**
!content_vault/scratch/.gitkeep

# Scratch / Temp files
scratch/**
!scratch/.gitkeep

# CSV exports at root level
success.csv
content_export_*.csv

# ============================================================
# Image & Media file types (safety net)
# ============================================================
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.mp4
*.webm
*.mov
*.avi
# Exceptions: UI assets
!frontend/public/**/*.png
!frontend/public/**/*.jpg
!frontend/public/**/*.jpeg
!frontend/public/**/*.gif
!frontend/public/**/*.webp
!public/**/*.png
!public/**/*.jpg
!public/**/*.ico
!public/**/*.svg
