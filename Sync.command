#!/bin/bash

# ============================================================
#  Sync.command — sync โค้ดกับ GitHub แบบปลอดภัย (ใช้ได้ทุกเครื่อง)
#  ทำงาน 3 ขั้น:  1) เซฟงานในเครื่องนี้  2) ดึงของใหม่จาก GitHub  3) อัปขึ้น GitHub
#  ดับเบิลคลิกไฟล์นี้ทุกครั้ง "ก่อนเริ่มทำงาน" และ "หลังทำงานเสร็จ"
# ============================================================

cd "$(dirname "$0")"

echo "=========================================================="
echo " 🔄 กำลัง Sync โค้ดกับ GitHub..."
echo "=========================================================="

# ตรวจว่าอยู่ใน git repo จริง
if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ โฟลเดอร์นี้ไม่ใช่ git repo — หยุดทำงาน"
    echo "กด Enter เพื่อปิด..."; read -r; exit 1
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)
echo "📍 อยู่บน branch: $BRANCH"
echo ""

# ---------- ขั้น 1: เซฟงานในเครื่องนี้ก่อน (ถ้ามีการแก้ไขที่ยังไม่ commit) ----------
if [ -n "$(git status --porcelain)" ]; then
    echo "📝 พบการแก้ไขที่ยังไม่ได้บันทึกในเครื่องนี้:"
    git status --short
    echo ""
    DEFAULT_MSG="wip: $(hostname -s) $(date '+%Y-%m-%d %H:%M')"
    read -r -p "พิมพ์คำอธิบายการแก้ไข (กด Enter เพื่อใช้ค่าเริ่มต้น): " MSG
    [ -z "$MSG" ] && MSG="$DEFAULT_MSG"
    git add -A
    git commit -m "$MSG" || { echo "❌ commit ไม่สำเร็จ"; read -r; exit 1; }
    echo "   ✅ บันทึกงานในเครื่องนี้แล้ว"
else
    echo "✅ ไม่มีการแก้ไขค้าง — ข้ามขั้นบันทึก"
fi
echo ""

# ---------- ขั้น 2: ดึงของใหม่จาก GitHub ----------
echo "⬇️  กำลังดึงโค้ดใหม่จาก GitHub..."
if ! git pull --no-rebase origin "$BRANCH"; then
    echo ""
    echo "⚠️ ====================================================="
    echo " มี CONFLICT! — โค้ดเครื่องนี้ชนกับโค้ดบน GitHub"
    echo " งานของคุณยัง 'ไม่หาย' (commit ไว้แล้วในขั้น 1)"
    echo ""
    echo " 👉 อย่าเพิ่งทำอะไรต่อ ให้เปิด Claude/โปรแกรมแก้โค้ด"
    echo "    แล้วบอกว่า 'ช่วยแก้ git conflict ให้หน่อย'"
    echo " ===================================================="
    echo "กด Enter เพื่อปิด..."; read -r; exit 1
fi
echo "   ✅ ได้โค้ดล่าสุดแล้ว"
echo ""

# ---------- ขั้น 3: อัปขึ้น GitHub ----------
echo "⬆️  กำลังอัปขึ้น GitHub..."
if ! git push origin "$BRANCH"; then
    echo "❌ push ไม่สำเร็จ (อาจต้อง login GitHub หรือเน็ตมีปัญหา)"
    read -r; exit 1
fi

echo ""
echo "=========================================================="
echo " 🎉 Sync เสร็จเรียบร้อย! เครื่องนี้กับ GitHub ตรงกันแล้ว"
echo "=========================================================="
echo "กด Enter เพื่อปิดหน้าต่างนี้..."
read -r
